(ns test.render-test
  (:require [test :refer :all]
            [string]
            [legmacs.buffer :as buf]
            [legmacs.modes :as modes]
            [legmacs.render :as r]
            [legmacs.buffers :as bufs]))

(deftest pad-right-behavior
  (testing "pads short strings, truncates long ones, leaves exact-width alone"
    (is (= "ab  " (r/pad-right "ab" 4)))
    (is (= "abcd" (r/pad-right "abcdef" 4)))
    (is (= "abcd" (r/pad-right "abcd" 4)))))

(deftest gutter-width-grows-with-line-count
  (testing "gutter has room for the largest line number plus a separator"
    (is (= 4 (r/gutter-width 9)))
    (is (= 4 (r/gutter-width 99)))
    (is (= 5 (r/gutter-width 100)))
    (is (= 6 (r/gutter-width 1000)))))

(deftest dims-reserve-status-and-echo-rows
  (testing "text-rows is rows minus 2; text-cols is cols minus the gutter"
    (let [s (buf/new-state nil ["a"])
          d (r/dims s 80 24)]
      (is (= 22 (:text-rows d)))
      (is (= (- 80 (:gutter d)) (:text-cols d))))))

(deftest frame-contains-visible-text
  (testing "buffer lines, filename, and position show up in the frame"
    (let [s (buf/new-state "foo.txt" ["hello world" "second line"])
          s (buf/ensure-visible s 10 40)
          out (r/frame s 40 12)]
      (is (string/includes? out "hello world"))
      (is (string/includes? out "second line"))
      (is (string/includes? out "foo.txt"))
      (is (string/includes? out "Ln 1, Col 1")))))

(deftest frame-shows-active-mode
  (testing "the status line shows the active mode's name in parens"
    (let [s (assoc (buf/new-state "x.lg" ["x"]) :mode :let-go)
          s (buf/ensure-visible s 10 40)
          out (r/frame s 40 12)]
      (is (string/includes? out "(let-go)"))))

  (testing "no mode set shows no mode label"
    (let [s (buf/new-state "x.txt" ["x"])
          s (buf/ensure-visible s 10 40)
          out (r/frame s 40 12)]
      (is (not (string/includes? out "(let-go)"))))))

(deftest frame-shows-scratch-buffer-name
  (testing "a buffer with no filename is labeled *scratch*"
    (let [s (buf/new-state nil [""])
          s (buf/ensure-visible s 10 40)
          out (r/frame s 40 12)]
      (is (string/includes? out "*scratch*")))))

(deftest frame-shows-minibuffer-prompt
  (testing "an active minibuffer replaces the echo area with prompt+input"
    (let [s (buf/new-state nil ["x"])
          s (assoc s :minibuffer {:prompt "Find file: " :input "foo" :cursor-col 3})
          s (buf/ensure-visible s 10 40)
          out (r/frame s 40 12)]
      (is (string/includes? out "Find file: foo")))))

(deftest frame-shows-message
  (testing "a status message shows in the echo area when no minibuffer is active"
    (let [s (assoc (buf/new-state nil ["x"]) :message "Wrote foo.txt")
          s (buf/ensure-visible s 10 40)
          out (r/frame s 40 12)]
      (is (string/includes? out "Wrote foo.txt")))))

(deftest minibuffer-height-defaults-to-one
  (testing "no minibuffer / single-line message keeps the classic 2-row bottom"
    (let [s (buf/new-state nil ["a"])]
      (is (= 1 (r/minibuffer-height s 80 24)))
      (is (= 1 (r/minibuffer-height (assoc s :message "hi") 80 24))))))

(deftest minibuffer-list-grows-and-shrinks-text
  (testing "a candidate list reserves prompt + candidate rows, stealing them from the text area"
    (let [s (assoc (buf/new-state nil ["a"])
                   :minibuffer {:prompt "swiper: " :input "" :cursor-col 0
                                :list-kind :swiper :selection 0
                                :candidates [{:row 0 :col 0 :end 1 :label "1: a"}
                                             {:row 0 :col 0 :end 1 :label "1: a"}]})]
      (is (= 3 (r/minibuffer-height s 80 24)))          ; 1 prompt + 2 candidates
      (is (= (- 24 1 3) (:text-rows (r/dims s 80 24)))))))

(deftest minibuffer-height-never-eats-the-whole-screen
  (testing "even a huge candidate list leaves at least one text row plus the status line"
    (let [cands (vec (repeat 100 {:row 0 :col 0 :end 1 :label "x"}))
          s (assoc (buf/new-state nil ["a"])
                   :minibuffer {:prompt "p" :input "" :cursor-col 0 :candidates cands :selection 0})
          d (r/dims s 80 10)]
      (is (<= (:mb-rows d) (- 10 2)))
      (is (>= (:text-rows d) 1))
      (is (= 10 (+ (:text-rows d) 1 (:mb-rows d)))))))     ; text + status + echo == rows

(deftest multi-line-message-expands-without-overflowing
  (testing "a message with newlines becomes several padded rows, not a raw newline in the frame"
    (let [s (assoc (buf/new-state nil ["x"]) :message "line one\nline two\nline three")]
      (is (= 3 (r/minibuffer-height s 80 24)))
      (let [out (r/frame s 80 24)]
        (is (string/includes? out "line one"))
        (is (string/includes? out "line three"))))))

(deftest message-control-chars-are-caret-escaped
  (testing "a message carrying raw control bytes renders in caret notation
            instead of letting the terminal execute them"
    (let [s (assoc (buf/new-state nil ["x"]) :message (str "boom " (char 27) "[H" (char 7)))
          out (r/frame s 40 12)]
      (is (string/includes? out "boom ^[[H^G"))))

  (testing "explicit newlines still split into rows -- only the bytes inside
            each line are escaped"
    (is (= ["a" "^[x"] (vec (r/message-lines (str "a\n" (char 27) "x") 40))))))

(defn- fit [s cols rows] (r/scroll-to-fit s (r/dims s cols rows)))

(deftest echo-area-growth-does-not-permanently-scroll
  (testing "a transient multi-line message scrolls the view only while shown"
    (let [s (-> (buf/new-state nil (vec (map str (range 40))))
                (assoc :cursor-row 21)
                (fit 80 24))]
      (is (= 0 (:scroll-row s)))                          ; 22 text rows, cursor on the last
      (let [shown (fit (assoc s :message "a\nb\nc\nd\ne") 80 24)]
        (is (= 4 (:scroll-row shown)))                    ; 5 echo rows -> 18 text rows
        (is (= 0 (:scroll-anchor shown)))
        (let [cleared (fit (assoc shown :message nil) 80 24)]
          (is (= 0 (:scroll-row cleared)))                ; original scroll restored
          (is (nil? (:scroll-anchor cleared)))))))

  (testing "the anchor is dropped, not restored, when the cursor moved out of
            its window while the echo area was grown"
    (let [s (-> (buf/new-state nil (vec (map str (range 40))))
                (assoc :cursor-row 21)
                (fit 80 24))
          shown (fit (assoc s :message "a\nb\nc\nd\ne") 80 24)
          moved (fit (assoc shown :message nil :cursor-row 39) 80 24)]
      (is (= (- 39 21) (:scroll-row moved)))              ; plain ensure-visible result
      (is (nil? (:scroll-anchor moved)))))

  (testing "no anchor is recorded when the grown echo area needs no scroll"
    (let [s (-> (buf/new-state nil (vec (map str (range 40))))
                (assoc :cursor-row 2)
                (fit 80 24))
          shown (fit (assoc s :message "a\nb\nc\nd\ne") 80 24)]
      (is (= 0 (:scroll-row shown)))
      (is (nil? (:scroll-anchor shown))))))

(deftest swiper-current-match-highlighted-in-buffer
  (testing "the selected swiper match paints search-current-bg on its buffer line"
    (let [s (assoc (buf/new-state nil ["hello world"])
                   :minibuffer {:prompt "swiper: " :input "world" :cursor-col 5
                                :list-kind :swiper :selection 0
                                :candidates [{:row 0 :col 6 :end 11 :label "1: hello world"}]})
          s (buf/ensure-visible s 10 40)
          out (r/frame s 40 24)]
      (is (string/includes? out r/search-current-bg)))))

(deftest overlay-replaces-the-frame
  (testing "an overlay shows its title and lines instead of the buffer"
    (let [s (assoc (buf/new-state nil ["x"]) :overlay {:title "Key Bindings" :lines ["C-a  move-beginning-of-line"]})
          out (r/frame s 40 12)]
      (is (string/includes? out "Key Bindings"))
      (is (string/includes? out "move-beginning-of-line"))
      (is (string/includes? out "press any key")))))

(deftest active-region-is-highlighted
  (testing "an active region shows region-bg somewhere in the frame"
    (let [s (assoc (buf/new-state nil ["hello world"]) :mark [0 0] :cursor-row 0 :cursor-col 5)
          s (buf/ensure-visible s 10 40)
          out (r/frame s 40 12)]
      (is (string/includes? out r/region-bg))))

  (testing "no mark set -> no highlight at all"
    (let [s (buf/new-state nil ["hello world"])
          s (buf/ensure-visible s 10 40)
          out (r/frame s 40 12)]
      (is (not (string/includes? out r/region-bg))))))

(deftest cursor-placement-accounts-for-gutter-and-scroll
  (testing "cursor lands at gutter + (cursor-col - scroll-col), row offset by scroll-row"
    (let [s (buf/new-state nil (vec (map str (range 30))))
          s (assoc s :cursor-row 12 :cursor-col 0)
          s (buf/ensure-visible s 10 40)
          layout (r/dims s 40 12)]
      (is (= [(inc (:gutter layout)) (inc (- 12 (:scroll-row s)))]
             (r/cursor-placement s layout 1 12))))))

(deftest mode-highlighter-colors-the-frame
  (testing "a mode's :highlighter contributes fg spans for its visible lines"
    (let [km (atom {})]
      (modes/register-mode! :test-render-hl km "hl test"
                             {:highlighter (fn [line] (if (string/includes? line "shout")
                                                         [{:start 0 :end (count line) :style :keyword}]
                                                         []))})
      (let [s (-> (buf/new-state nil ["shout" "quiet"])
                  (modes/switch-to-mode :test-render-hl)
                  (buf/ensure-visible 10 40))
            out (r/frame s 40 12)]
        (is (string/includes? out (get r/fg-color-for :keyword)))))))

(deftest paren-match-is-highlighted
  (testing ":paren-match spans both ends, even on different rows"
    (let [s (-> (buf/new-state nil ["(foo" "bar)"])
                (assoc :paren-match [[0 0] [1 3]])
                (buf/ensure-visible 10 40))
          out (r/frame s 40 12)]
      (is (string/includes? out (get r/fg-color-for :paren-match)))
      (is (string/includes? out (get r/bg-color-for :paren-match))))))

(deftest recenter-centers-point
  (testing "the :recenter flag centers point in the window and is consumed"
    (let [s (-> (buf/new-state nil (vec (map str (range 100))))
                (assoc :cursor-row 50 :recenter true)
                (fit 80 24))]
      (is (= 39 (:scroll-row s)))                         ; 50 - (22/2)
      (is (nil? (:recenter s)))))

  (testing "recentering near the top clamps at zero"
    (let [s (-> (buf/new-state nil (vec (map str (range 100))))
                (assoc :cursor-row 3 :recenter true)
                (fit 80 24))]
      (is (= 0 (:scroll-row s))))))

;; --- multi-window frames ------------------------------------------------

(deftest workspace-frame-draws-side-by-side-windows-with-a-divider
  (testing "a :beside split shows both windows' text and a │ divider column"
    (let [ws (bufs/new-workspace (buf/new-state "left.txt" ["left text here"]))
          ws (bufs/put-current ws (assoc (bufs/current ws) :buffer-command {:op :split :dir :beside}))
          ws (r/prepare-workspace ws 80 24)
          out (r/workspace-frame ws 80 24)]
      (is (string/includes? out "left text here"))
      (is (string/includes? out "│"))
      ;; both windows carry their own mode line naming the buffer
      (is (<= 3 (count (string/split out "left.txt")))))))

(deftest workspace-frame-stacked-windows-show-different-buffers
  (testing "each window of a :below split renders its own buffer"
    (let [ws (bufs/new-workspace (buf/new-state "one.txt" ["first buffer"]))
          ws (bufs/put-current ws (assoc (bufs/current ws) :buffer-command {:op :split :dir :below}))
          ws (bufs/put-current ws (assoc (bufs/current ws)
                                          :buffer-command {:op :open-new :state (buf/new-state "two.txt" ["second buffer"])}))
          ws (r/prepare-workspace ws 80 24)
          out (r/workspace-frame ws 80 24)]
      (is (string/includes? out "first buffer"))
      (is (string/includes? out "second buffer"))
      ;; no divider rows between stacked windows -- mode lines separate them
      (is (not (string/includes? out "│"))))))

(deftest single-window-workspace-frame-matches-flat-frame
  (testing "with one window, the workspace path and the flat path agree exactly"
    (let [ws (bufs/new-workspace (buf/new-state "a.txt" ["hello" "world"]))
          ws (r/prepare-workspace ws 60 18)
          flat (bufs/current ws)]
      (is (= (r/frame flat 60 18) (r/workspace-frame ws 60 18))))))

(deftest prepare-workspace-clamps-an-inactive-windows-view
  (testing "an inactive window whose buffer shrank gets its cursor/scroll pulled back in"
    (let [ws (bufs/new-workspace (buf/new-state nil (vec (map str (range 50)))))
          ws (bufs/put-current ws (assoc (bufs/current ws) :cursor-row 45 :scroll-row 40))
          ws (bufs/put-current ws (assoc (bufs/current ws) :buffer-command {:op :split :dir :below}))
          ws (bufs/put-current ws (assoc (bufs/current ws) :buffer-command {:op :other-window}))
          ;; shrink the buffer from the now-active window 1
          ws (bufs/put-current ws (assoc (bufs/current ws) :lines ["a" "b"] :cursor-row 0 :scroll-row 0))
          ws (r/prepare-workspace ws 80 24)
          w0 (bufs/flat-for-window ws 0)]
      (is (<= (:cursor-row w0) 1))
      (is (<= (:scroll-row w0) 1)))))

(deftest workspace-frame-cursor-lands-in-the-active-window
  (testing "the cursor escape targets the active window's rectangle, not the screen origin"
    (let [ws (bufs/new-workspace (buf/new-state nil ["abc" "def"]))
          ws (bufs/put-current ws (assoc (bufs/current ws) :buffer-command {:op :split :dir :below}))
          ws (bufs/put-current ws (assoc (bufs/current ws) :buffer-command {:op :other-window}))
          ws (r/prepare-workspace ws 80 24)
          out (r/workspace-frame ws 80 24)]
      ;; window 0 holds screen rows 1-12 (11 text rows + its mode line),
      ;; so window 1's first text row is 13; cursor at buffer 0,0 lands
      ;; there, in col 5 (just past the 4-column gutter)
      (is (string/ends-with? out (str (char 27) "[13;5H" (char 27) "[?25h"))))))

;; --- tabs and control characters in buffer text --------------------------
;;
;; (char 9) instead of a literal escape, per the CLAUDE.md gotcha about
;; writing control characters into .lg sources.

(deftest tabs-are-expanded-for-display
  (testing "line-display expands a leading tab to the next tab stop, with a column map"
    (let [d (r/line-display (str (char 9) "ab") 4)]
      (is (= "    ab" (:text d)))
      (is (= [0 4 5 6] (:cols d)))))

  (testing "a tab mid-line pads only to the next stop, not a fixed width"
    (is (= "ab  c" (:text (r/line-display (str "ab" (char 9) "c") 4)))))

  (testing "other control characters become caret notation instead of going out raw"
    (let [d (r/line-display (str "a" (char 27) "b") 4)]
      (is (= "a^[b" (:text d)))
      (is (= [0 1 3 4] (:cols d))))))

(deftest frames-never-contain-raw-buffer-control-characters
  (testing "a tab-indented line paints spaces; a raw tab would skip terminal
            cells and let the previous frame show through"
    (let [s (-> (buf/new-state "x.go" [(str (char 9) "for i := 0") "plain"])
                (buf/ensure-visible 10 60))
          out (r/frame s 60 12)]
      (is (not (string/includes? out (str (char 9)))))
      (is (string/includes? out "    for i := 0")))))

(deftest cursor-and-scroll-account-for-tab-display-width
  (testing "point just after a tab lands at the tab's display width, not char index 1"
    (let [s (assoc (buf/new-state nil [(str (char 9) "abc")]) :cursor-col 1)
          layout (r/dims s 40 10)
          [col _row] (r/cursor-placement s layout 1 10)]
      (is (= (+ (:gutter layout) 4 1) col))))

  (testing "scroll-to-fit chases the cursor in display columns on tab-heavy lines"
    (let [line (apply str (concat (repeat 30 (char 9)) ["x"]))
          s (assoc (buf/new-state nil [line]) :cursor-col 30)
          s (r/scroll-to-fit s {:text-rows 5 :text-cols 20 :mb-rows 1})]
      ;; char 30 sits at display column 120; the window is 20 wide
      (is (= 101 (:scroll-col s))))))
