(ns test.keys-test
  (:require [test :refer :all]
            [string]
            [legmacs.keys :as k]))

(defn- esc [s] (str (char 27) s))

(deftest control-chords
  (testing "raw control bytes map to C-<letter>"
    (is (= "C-a" (k/raw->chord (str (char 1)))))
    (is (= "C-x" (k/raw->chord (str (char 24)))))
    (is (= "C-z" (k/raw->chord (str (char 26)))))
    (is (= "C-_" (k/raw->chord (str (char 31)))))
    (is (= "C-SPC" (k/raw->chord (str (char 0))))
        "Ctrl-Space is sent as NUL by every terminal, not a printable space -- must not be mistaken for self-insert or EOF")
    (is (= "C-j" (k/raw->chord (str (char 10))))
        "LF/byte 10 is Ctrl-J, distinct from RET (CR/byte 13) -- needed for eval-print-last-sexp")
    (is (= "C-g" (k/raw->chord (str (char 7))))
        "BEL/byte 7 is genuinely also Ctrl-G; term/read-key reuses it as a resize wake-up too, but mapping it to C-g is the only choice that lets a real Ctrl-G keypress work at all -- see raw->chord's docstring")))

(deftest named-keys
  (testing "RET, TAB, DEL, ESC"
    (is (= "RET" (k/raw->chord (str (char 13)))))
    (is (= "TAB" (k/raw->chord (str (char 9)))))
    (is (= "DEL" (k/raw->chord (str (char 127)))))
    (is (= "ESC" (k/raw->chord (str (char 27)))))))

(deftest arrow-and-nav-keys
  (testing "CSI sequences map to direction/navigation names"
    (is (= "up" (k/raw->chord (esc "[A"))))
    (is (= "down" (k/raw->chord (esc "[B"))))
    (is (= "left" (k/raw->chord (esc "[D"))))
    (is (= "right" (k/raw->chord (esc "[C"))))
    (is (= "home" (k/raw->chord (esc "[H"))))
    (is (= "end" (k/raw->chord (esc "[F"))))
    (is (= "delete" (k/raw->chord (esc "[3~"))))
    (is (= "insert" (k/raw->chord (esc "[2~"))))
    (is (= "pageup" (k/raw->chord (esc "[5~"))))
    (is (= "pagedown" (k/raw->chord (esc "[6~"))))
    (is (= "f1" (k/raw->chord (esc "OP"))))
    (is (= "f4" (k/raw->chord (esc "OS"))))))

(deftest modified-csi-sequences
  (testing "xterm modifier parameters decode into C-/M-/S- chord prefixes"
    (is (= "C-left" (k/raw->chord (esc "[1;5D"))))
    (is (= "C-right" (k/raw->chord (esc "[1;5C"))))
    (is (= "M-up" (k/raw->chord (esc "[1;3A"))))
    (is (= "S-right" (k/raw->chord (esc "[1;2C"))))
    (is (= "C-M-down" (k/raw->chord (esc "[1;7B"))))
    (is (= "C-S-left" (k/raw->chord (esc "[1;6D"))))
    (is (= "C-home" (k/raw->chord (esc "[1;5H"))))
    (is (= "M-end" (k/raw->chord (esc "[1;3F"))))
    (is (= "C-delete" (k/raw->chord (esc "[3;5~"))))
    (is (= "S-pageup" (k/raw->chord (esc "[5;2~"))))
    (is (= "C-f1" (k/raw->chord (esc "[1;5P"))))
    (is (= "f5" (k/raw->chord (esc "[15~"))))
    (is (= "C-f5" (k/raw->chord (esc "[15;5~"))))
    (is (= "f12" (k/raw->chord (esc "[24~"))))))

(deftest unknown-sequences-are-caret-escaped
  (testing "a chord never carries raw control bytes -- dispatch embeds it in
            the echo message and the terminal would execute them"
    (is (= "^[[999z" (k/raw->chord (esc "[999z"))))
    (is (= "^[[27;5;106~" (k/raw->chord (esc "[27;5;106~"))))
    (is (= "^[Ox" (k/raw->chord (esc "Ox"))))
    (is (not (string/includes? (k/raw->chord (esc "[1;99Q")) (str (char 27)))))))

(deftest printable-chars
  (testing "plain characters pass through unchanged"
    (is (= "a" (k/raw->chord "a")))
    (is (= " " (k/raw->chord " ")))
    (is (k/printable? "a"))
    (is (k/printable? "Z"))
    (is (not (k/printable? "RET")))
    (is (not (k/printable? "DEL")))
    (is (not (k/printable? "ESC")))
    (is (not (k/printable? "C-a")))
    (is (not (k/printable? "M-x")))
    (is (not (k/printable? "up")))))

(deftest meta-combination
  (testing "meta-chord prefixes whatever came after a lone ESC with M-"
    (is (= "M-x" (k/meta-chord "x")))
    (is (= "M-C-f" (k/meta-chord "C-f")))
    (is (= "ESC" (k/meta-chord "ESC")))
    (is (= "ESC" (k/meta-chord nil)))
    (is (= :resize (k/meta-chord :resize)))))

(deftest bracketed-paste-token-accumulation
  (testing "raw tokens between the paste markers concatenate into literal text"
    (is (= "hello" (k/paste-tokens->text ["h" "e" "l" "l" "o"])))
    (is (= "" (k/paste-tokens->text []))))

  (testing "a bare CR byte inside a paste becomes a newline, not the RET chord
            it would decode to outside of one"
    (is (= "line one\nline two"
           (k/paste-tokens->text ["l" "i" "n" "e" " " "o" "n" "e" (str (char 13))
                                   "l" "i" "n" "e" " " "t" "w" "o"]))))

  (testing "multi-byte runes (already whole tokens from term/read-key) pass through"
    (is (= "café" (k/paste-tokens->text ["c" "a" "f" "é"])))))

(deftest paste-event-shape
  (testing "paste? / paste-text recognize the tagged tuple read-chord returns for a paste"
    (is (k/paste? [:paste "hi"]))
    (is (= "hi" (k/paste-text [:paste "hi"])))
    (is (not (k/paste? "a")))
    (is (not (k/paste? "C-x")))
    (is (not (k/paste? nil)))))
