(ns test.buffer-test
  (:require [test :refer :all]
            [legmacs.buffer :as buf]))

(deftest split-and-join
  (testing "split-lines / join-lines round-trip"
    (is (= ["a" "b" "c"] (buf/split-lines "a\nb\nc\n")))
    (is (= ["a" "b" "c"] (buf/split-lines "a\nb\nc")))
    (is (= [""] (buf/split-lines "")))
    (is (= "a\nb\n" (buf/join-lines ["a" "b"])))))

(deftest insertion
  (testing "typing characters"
    (let [s (buf/new-state nil [""])
          s (buf/insert-string s "hi")]
      (is (= ["hi"] (:lines s)))
      (is (= 2 (:cursor-col s)))
      (is (:modified? s))))

  (testing "inserting text with newlines splits the line"
    (let [s (buf/new-state nil ["abcd"])
          s (assoc s :cursor-col 2)
          s (buf/insert-string s "X\nY")]
      (is (= ["abX" "Ycd"] (:lines s)))
      (is (= 1 (:cursor-row s)))
      (is (= 1 (:cursor-col s)))))

  (testing "RET splits the current line"
    (let [s (buf/new-state nil ["hello world"])
          s (assoc s :cursor-col 5)
          s (buf/insert-newline s)]
      (is (= ["hello" " world"] (:lines s)))
      (is (= 1 (:cursor-row s)))
      (is (= 0 (:cursor-col s))))))

(deftest deletion
  (testing "delete-char-forward at end of line joins with next"
    (let [s (buf/new-state nil ["foo" "bar"])
          s (assoc s :cursor-col 3)
          s (buf/delete-char-forward s)]
      (is (= ["foobar"] (:lines s)))
      (is (= 1 (count (:lines s))))))

  (testing "delete-char-backward at column 0 joins with previous line"
    (let [s (buf/new-state nil ["foo" "bar"])
          s (assoc s :cursor-row 1 :cursor-col 0)
          s (buf/delete-char-backward s)]
      (is (= ["foobar"] (:lines s)))
      (is (= 0 (:cursor-row s)))
      (is (= 3 (:cursor-col s))))))

(deftest kill-and-yank
  (testing "C-k kills to end of line, C-y yanks it back"
    (let [s (buf/new-state nil ["hello world"])
          s (assoc s :cursor-col 5)
          s (buf/kill-line s)]
      (is (= ["hello"] (:lines s)))
      (is (= " world" (:clipboard s)))
      (let [s (buf/yank s)]
        (is (= ["hello world"] (:lines s)))))))

(deftest undo-redo
  (testing "undo restores the previous shape; redo replays it"
    (let [s (buf/new-state nil ["abc"])
          s (buf/insert-string s "X")
          s (buf/undo s)]
      (is (= ["abc"] (:lines s)))
      (let [s (buf/redo s)]
        (is (= ["Xabc"] (:lines s)))))))

(deftest movement
  (testing "left/right/up/down respect line boundaries"
    (let [s (buf/new-state nil ["ab" "cd"])
          s (assoc s :cursor-row 0 :cursor-col 2)
          s (buf/move-right s)]
      (is (= 1 (:cursor-row s)))
      (is (= 0 (:cursor-col s)))
      (let [s (buf/move-left s)]
        (is (= 0 (:cursor-row s)))
        (is (= 2 (:cursor-col s))))))

  (testing "move-word-forward / move-word-backward skip whole words"
    (let [s (buf/new-state nil ["foo  bar baz"])
          s (buf/move-word-forward s)]
      (is (= 3 (:cursor-col s)))
      (let [s (buf/move-word-forward s)]
        (is (= 8 (:cursor-col s)))
        (let [s (buf/move-word-backward s)]
          (is (= 5 (:cursor-col s))))))))

(deftest scrolling
  (testing "ensure-visible scrolls the viewport to keep the cursor on screen"
    (let [lines (vec (map str (range 50)))
          s (buf/new-state nil lines)
          s (assoc s :cursor-row 30)
          s (buf/ensure-visible s 10 80)]
      (is (<= (:scroll-row s) 30))
      (is (< 30 (+ (:scroll-row s) 10))))))

(deftest word-kills
  (testing "kill-word removes to the end of the next word, into the clipboard"
    (let [s (buf/new-state nil ["foo bar baz"])
          s (buf/kill-word s)]
      (is (= [" bar baz"] (:lines s)))
      (is (= "foo" (:clipboard s)))
      (let [s (buf/kill-word s)]
        (is (= [" baz"] (:lines s)))
        (is (= " bar" (:clipboard s))))))

  (testing "kill-word joins lines when the next word starts on the next line"
    (let [s (buf/new-state nil ["foo" "bar"])
          s (assoc s :cursor-col 3)
          s (buf/kill-word s)]
      (is (= ["foo"] (:lines s)))
      (is (= "\nbar" (:clipboard s)))))

  (testing "backward-kill-word removes the previous word, leaving point at its start"
    (let [s (buf/new-state nil ["foo bar baz"])
          s (assoc s :cursor-col 7)
          s (buf/backward-kill-word s)]
      (is (= ["foo  baz"] (:lines s)))
      (is (= "bar" (:clipboard s)))
      (is (= 4 (:cursor-col s)))))

  (testing "kill-word at end of buffer is a no-op"
    (let [s (buf/new-state nil ["foo"])
          s (assoc s :cursor-col 3)
          s (buf/kill-word s)]
      (is (= ["foo"] (:lines s))))))

(deftest paragraph-motion
  (testing "forward-paragraph lands on the blank line after the paragraph"
    (let [s (buf/new-state nil ["one" "two" "" "three" "" "four"])
          s (buf/move-paragraph-forward s)]
      (is (= 2 (:cursor-row s)))
      (is (= 0 (:cursor-col s)))
      (let [s (buf/move-paragraph-forward s)]
        (is (= 4 (:cursor-row s))))))

  (testing "forward-paragraph with no trailing blank line stops at buffer end"
    (let [s (buf/new-state nil ["one" "two"])
          s (buf/move-paragraph-forward s)]
      (is (= 1 (:cursor-row s)))
      (is (= 3 (:cursor-col s)))))

  (testing "backward-paragraph lands on the blank line before the paragraph"
    (let [s (buf/new-state nil ["one" "" "two" "three"])
          s (assoc s :cursor-row 3)
          s (buf/move-paragraph-backward s)]
      (is (= 1 (:cursor-row s)))
      (is (= 0 (:cursor-col s)))
      (let [s (buf/move-paragraph-backward s)]
        (is (= 0 (:cursor-row s)))))))

(deftest read-only-blocks-region-and-word-kills
  (testing "delete-region and the word kills refuse on a read-only buffer"
    (let [s (assoc (buf/new-state nil ["foo bar"]) :read-only? true)
          s (assoc s :mark [0 0] :cursor-col 3)]
      (is (= ["foo bar"] (:lines (buf/delete-region s))))
      (is (= "Buffer is read-only" (:message (buf/delete-region s))))
      (is (= ["foo bar"] (:lines (buf/kill-word s))))
      (is (= ["foo bar"] (:lines (buf/backward-kill-word s))))
      (is (= "" (:clipboard (buf/kill-word s)))))))

(deftest mark-ring
  (testing "pop-mark jumps back to the last pushed position and consumes it"
    (let [s (-> (buf/new-state nil ["a" "b" "c"])
                (assoc :cursor-row 0 :cursor-col 0)
                buf/push-mark
                (assoc :cursor-row 2 :cursor-col 1)
                buf/pop-mark)]
      (is (= [0 0] [(:cursor-row s) (:cursor-col s)]))
      (is (= () (:mark-ring s)))))

  (testing "repeated pops walk further back through jump history, most recent first"
    (let [s (-> (buf/new-state nil ["a" "b" "c"])
                (assoc :cursor-row 0 :cursor-col 0) buf/push-mark
                (assoc :cursor-row 1 :cursor-col 0) buf/push-mark
                (assoc :cursor-row 2 :cursor-col 0))
          s1 (buf/pop-mark s)
          s2 (buf/pop-mark s1)]
      (is (= [1 0] [(:cursor-row s1) (:cursor-col s1)]))
      (is (= [0 0] [(:cursor-row s2) (:cursor-col s2)]))))

  (testing "an empty ring is a no-op with a message, point unmoved"
    (let [s (buf/pop-mark (assoc (buf/new-state nil ["a"]) :cursor-col 0))]
      (is (= [0 0] [(:cursor-row s) (:cursor-col s)]))
      (is (= "No previous mark to jump back to" (:message s)))))

  (testing "bounded to mark-ring-limit entries -- oldest pushes fall off"
    (let [s (reduce (fn [s i] (buf/push-mark (assoc s :cursor-row 0 :cursor-col i)))
                     (buf/new-state nil ["x"])
                     (range (+ 5 buf/mark-ring-limit)))]
      (is (= buf/mark-ring-limit (count (:mark-ring s))))
      (is (= (dec (+ 5 buf/mark-ring-limit)) (second (first (:mark-ring s))))
          "newest push is still on top")))

  (testing "clamped if the buffer has shrunk since the mark was pushed"
    (let [s (-> (buf/new-state nil ["a" "b" "c"])
                (assoc :cursor-row 2 :cursor-col 0)
                buf/push-mark
                (assoc :lines ["a"] :cursor-row 0 :cursor-col 0)
                buf/pop-mark)]
      (is (= 0 (:cursor-row s))))))
